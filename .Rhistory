server_normalize <- function(input, output, session, state, plates) {
# --- Reactive: Selected Plate ---
selected_plate <- reactive({
req(state$screen == "normalize")
req(input$normalize_plate)
plates()[[input$normalize_plate]]
})
# --- Build group_map on the fly ---
group_map <- reactive({
plate <- selected_plate()
if (is.null(plate) || nrow(plate) == 0) return(data.frame())
# Flatten wells into group-level roles
df <- plate %>%
dplyr::mutate(
group = purrr::pmap_chr(list(is_control, is_blank, is_label, is_standard,
control_groups, blanks, labels, standards, standard_units),
function(is_control, is_blank, is_label, is_standard,
control_groups, blanks, labels, standards, standard_units) {
if (is_control && length(control_groups) > 0) return(paste(control_groups, collapse = ";"))
else if (is_blank && length(blanks) > 0) return(paste(blanks, collapse = ";"))
else if (is_standard && !is.na(standards)) return(as.character(standards))
else if (is_label && length(labels) > 0) return(paste(labels, collapse = ";"))
else return(NA_character_)
})
) %>%
tidyr::unnest(cols = c(group)) %>%
dplyr::mutate(role = dplyr::case_when(
is_control ~ "control",
is_blank ~ "blank",
is_standard ~ "standard",
is_label ~ "normal",
TRUE ~ "normal"
))
df
})
# --- Normalization ---
normalized_data <- reactive({
df <- group_map()
req(nrow(df) > 0)
# Compute blank mean per group
blank_means <- df %>%
dplyr::filter(role == "blank") %>%
dplyr::group_by(group) %>%
dplyr::summarize(blank_mean = mean(value, na.rm = TRUE), .groups = "drop")
# Subtract blank mean
df <- df %>% dplyr::left_join(blank_means, by = "group") %>%
dplyr::mutate(blank_corrected = value - blank_mean)
# Compute control mean per group
control_means <- df %>%
dplyr::filter(role == "control") %>%
dplyr::group_by(group) %>%
dplyr::summarize(control_mean = mean(blank_corrected, na.rm = TRUE), .groups = "drop")
df <- df %>% dplyr::left_join(control_means, by = "group") %>%
dplyr::mutate(
normalized_value = dplyr::case_when(
role %in% c("normal", "control") ~ blank_corrected / control_mean,
role == "standard" ~ blank_corrected,
TRUE ~ NA_real_
)
)
df
})
# --- Update SelectInput ---
observe({
req(plates())
updateSelectInput(session, "normalize_plate", choices = names(plates()))
})
# --- CSV Download ---
output$download_csv <- downloadHandler(
filename = function() paste0(input$normalize_plate, "_processed_data.csv"),
content = function(file) {
df <- normalized_data()
if (nrow(df) == 0) return(NULL)
write.csv(df %>% dplyr::select(row, col, group, role, value, blank_mean, control_mean, normalized_value),
file, row.names = FALSE)
}
)
# --- Prism Download ---
output$download_prism <- downloadHandler(
filename = function() paste0(input$normalize_plate, "_prism.csv"),
content = function(file) {
df <- normalized_data() %>% dplyr::filter(role %in% c("normal", "control"))
if (nrow(df) == 0) return(NULL)
prism <- df %>%
dplyr::mutate(sample = paste0(group, "_", row, col)) %>%
dplyr::select(sample, normalized_value) %>%
tidyr::pivot_wider(names_from = sample, values_from = normalized_value)
write.csv(prism, file, row.names = FALSE)
}
)
# --- Standards Download ---
output$download_standards <- downloadHandler(
filename = function() paste0(input$normalize_plate, "_standards.csv"),
content = function(file) {
df <- normalized_data() %>% dplyr::filter(role == "standard")
if (nrow(df) == 0) return(NULL)
write.csv(df %>% dplyr::select(row, col, group, value, blank_corrected), file, row.names = FALSE)
}
)
}
